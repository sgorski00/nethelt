POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=nh-db

DATABASE_URL="jdbc:postgresql://nh-postgres:5432/${POSTGRES_DB}"
DATABASE_USERNAME="${POSTGRES_USER}"
DATABASE_PASSWORD="${POSTGRES_PASSWORD}"

JWT_SECRET_KEY=paste_your_secret_key_here
JWT_EXPIRATION_TIME_MS=3600000
REFRESH_TOKEN_EXPIRATION_TIME_MS=604800000

GOOGLE_CLIENT_ID=paste_your_google_client_id_here
GOOGLE_CLIENT_SECRET=paste_your_google_client_secret_here
GITHUB_CLIENT_ID=paste_your_github_client_id_here
GITHUB_CLIENT_SECRET=paste_your_github_client_secret_here

FRONTEND_URL=http://localhost:80
FRONTEND_OAUTH2_SUCCESS_URL="${FRONTEND_URL}/oauth2/success"
ALLOWED_CORS_ORIGINS=http://localhost:80,http://localhost:3000,http://localhost:4200
